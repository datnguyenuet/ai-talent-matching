# ── TalentOS Environment Configuration ──────────────────────
# Copy this file to .env and fill in your values

# REQUIRED: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: PostgreSQL password (default: talentos_secret)
POSTGRES_PASSWORD=talentos_secret

# Optional: Port to expose the app on (default: 3000)
APP_PORT=3000

AI_PROVIDER=
GEMINI_API_KEY=

# Optional — Google OAuth (leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback